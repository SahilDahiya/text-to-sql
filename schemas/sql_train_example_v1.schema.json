{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sql_train_example_v1.schema.json",
  "title": "SQL Train Example v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "row_id",
    "source_benchmark",
    "source_split",
    "task_id",
    "db_id",
    "dialect",
    "question",
    "schema_text",
    "target_sql",
    "task_type",
    "provenance",
    "tags"
  ],
  "properties": {
    "schema_version": {"const": "sql_train_example:v1"},
    "row_id": {"type": "string", "minLength": 1},
    "source_benchmark": {
      "enum": ["spider", "bird", "livesqlbench", "synthetic", "smoke"]
    },
    "source_split": {
      "enum": ["train", "dev", "eval", "synthetic", "smoke"]
    },
    "task_id": {"type": "string", "minLength": 1},
    "db_id": {"type": "string", "minLength": 1},
    "db_path": {"type": ["string", "null"]},
    "dialect": {"enum": ["sqlite", "postgresql"]},
    "question": {"type": "string", "minLength": 1},
    "schema_text": {"type": "string", "minLength": 1},
    "knowledge_text": {"type": ["string", "null"]},
    "column_value_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "schema_linking_notes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "target_sql": {"type": "string", "minLength": 1},
    "task_type": {"enum": ["select", "management", "unknown"]},
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["created_by", "teacher_model", "source_path"],
      "properties": {
        "created_by": {"type": "string", "minLength": 1},
        "teacher_model": {"type": ["string", "null"]},
        "source_path": {"type": "string"}
      }
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
