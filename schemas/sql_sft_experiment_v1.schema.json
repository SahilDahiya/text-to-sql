{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sql_sft_experiment_v1.schema.json",
  "title": "SQL SFT Experiment v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "experiment_id",
    "student",
    "training_method",
    "train_inputs",
    "eval_plan",
    "output_paths"
  ],
  "properties": {
    "schema_version": {"const": "sql_sft_experiment:v1"},
    "experiment_id": {"type": "string", "minLength": 1},
    "student": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model_family", "base_model", "adapter_name"],
      "properties": {
        "model_family": {"type": "string", "minLength": 1},
        "base_model": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "adapter_name": {"type": "string", "minLength": 1},
        "initial_adapter_dir": {"type": ["string", "null"], "minLength": 1}
      }
    },
    "training_method": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "loss_target", "stage"],
      "properties": {
        "method": {"enum": ["lora_sft", "qlora_sft"]},
        "loss_target": {"const": "assistant_sql_only"},
        "stage": {"enum": ["direct_sql_sft", "execution_repair_sft", "tool_trajectory_sft"]},
        "notes": {"type": ["string", "null"]}
      }
    },
    "prompt": {
      "type": "object",
      "additionalProperties": false,
      "required": ["style"],
      "properties": {
        "style": {"enum": ["canonical_chat", "premsql_text"]}
      }
    },
    "train_inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": ["train_datasets", "validation_datasets"],
      "properties": {
        "train_datasets": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "validation_datasets": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "trainer": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "num_train_epochs",
        "per_device_train_batch_size",
        "gradient_accumulation_steps",
        "learning_rate",
        "logging_steps"
      ],
      "properties": {
        "backend": {
          "enum": ["transformers_trainer", "trl_sft_trainer"]
        },
        "num_train_epochs": {"type": "number", "exclusiveMinimum": 0},
        "per_device_train_batch_size": {"type": "integer", "minimum": 1},
        "gradient_accumulation_steps": {"type": "integer", "minimum": 1},
        "learning_rate": {"type": "number", "exclusiveMinimum": 0},
        "logging_steps": {"type": "integer", "minimum": 1},
        "attn_implementation": {
          "enum": [null, "sdpa", "flash_attention_2", "kernels-community/flash-attn2"]
        },
        "packing": {"type": "boolean"},
        "packing_strategy": {"enum": ["bfd"]},
        "max_length": {"type": ["integer", "null"], "minimum": 1},
        "bf16": {"type": ["boolean", "null"]},
        "tf32": {"type": ["boolean", "null"]},
        "gradient_checkpointing": {"type": "boolean"},
        "save_strategy": {"enum": ["no", "steps", "epoch"]},
        "save_steps": {"type": ["integer", "null"], "minimum": 1},
        "save_total_limit": {"type": ["integer", "null"], "minimum": 1},
        "auto_resume_from_checkpoint": {"type": "boolean"}
      }
    },
    "lora": {
      "type": "object",
      "additionalProperties": false,
      "required": ["r", "lora_alpha", "lora_dropout", "target_modules"],
      "properties": {
        "r": {"type": "integer", "minimum": 1},
        "lora_alpha": {"type": "integer", "minimum": 1},
        "lora_dropout": {"type": "number", "minimum": 0, "maximum": 1},
        "bias": {"enum": ["none", "all", "lora_only"]},
        "target_modules": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "quantization": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": {"enum": ["none", "bitsandbytes_4bit"]},
        "bnb_4bit_quant_type": {"enum": ["nf4", "fp4"]},
        "bnb_4bit_use_double_quant": {"type": "boolean"},
        "bnb_4bit_compute_dtype": {"enum": ["bfloat16", "float16", "float32"]},
        "device_map": {"enum": [null, "auto"]},
        "prepare_model_for_kbit_training": {"type": "boolean"}
      }
    },
    "eval_plan": {
      "type": "object",
      "additionalProperties": false,
      "required": ["smoke_dataset", "baseline_results", "post_train_results"],
      "properties": {
        "smoke_dataset": {"type": "string", "minLength": 1},
        "baseline_results": {"type": "string", "minLength": 1},
        "post_train_results": {"type": "string", "minLength": 1}
      }
    },
    "output_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": ["experiment_root", "adapter_dir", "train_summary_json", "eval_summary_json"],
      "properties": {
        "experiment_root": {"type": "string", "minLength": 1},
        "adapter_dir": {"type": "string", "minLength": 1},
        "train_summary_json": {"type": "string", "minLength": 1},
        "eval_summary_json": {"type": "string", "minLength": 1}
      }
    }
  }
}
