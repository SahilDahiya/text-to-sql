{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sql_train_example_v2.schema.json",
  "title": "SQL Train Example v2",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "row_id", "source_benchmark", "source_split", "task_id", "db_id", "db_path", "dialect", "question", "schema_text", "target_sql", "task_type", "provenance", "verification"],
  "properties": {
    "schema_version": {"const": "sql_train_example:v2"},
    "row_id": {"type": "string", "minLength": 1},
    "source_benchmark": {"const": "livesqlbench"},
    "source_split": {"enum": ["train", "dev", "eval", "challenge"]},
    "task_id": {"type": "string", "minLength": 1},
    "db_id": {"type": "string", "minLength": 1},
    "db_path": {"type": "string", "minLength": 1},
    "dialect": {"enum": ["postgresql", "sqlite"]},
    "question": {"type": "string", "minLength": 1},
    "schema_text": {"type": "string", "minLength": 1},
    "knowledge_text": {"type": ["string", "null"]},
    "target_sql": {"type": "string", "minLength": 1},
    "task_type": {"enum": ["select", "management"]},
    "provenance": {"$ref": "#/$defs/provenance"},
    "verification": {"$ref": "#/$defs/verification"}
  },
  "$defs": {
    "provenance": {
      "type": "object", "additionalProperties": false,
      "required": ["source_package", "source_revision", "source_task_path", "created_by", "target_source"],
      "properties": {
        "source_package": {"type": "string", "minLength": 1},
        "source_revision": {"type": "string", "minLength": 1},
        "source_task_path": {"type": "string", "minLength": 1},
        "created_by": {"type": "string", "minLength": 1},
        "target_source": {"enum": ["manual_verified", "independent_verified"]}
      }
    },
    "verification": {
      "type": "object", "additionalProperties": false,
      "required": ["status", "verified_by", "verification_id", "verified_at"],
      "properties": {
        "status": {"const": "execution_verified"},
        "verified_by": {"type": "string", "minLength": 1},
        "verification_id": {"type": "string", "minLength": 1},
        "verified_at": {"type": "string", "minLength": 1}
      }
    }
  }
}
